extends layout

block content
  - var destacadas = Array.isArray(destacadas) ? destacadas : []
  - var otras = Array.isArray(otras) ? otras : []

  h1 Comunidad de Fotografía
  if usuario
    p Has iniciado sesión como #{usuario.nombre}
    a(href='/publicacion/crear') Nueva publicación
  else
    p Explora las mejores imágenes y únete a la comunidad.
    a(href='/registro') Únete ahora

  h2 Imágenes destacadas
  .galeria
    each img in destacadas
      .card
        a(href=`/publicacion/${img.publicacion_id}`)
          img(src=img.ruta_archivo alt=img.titulo)
        p= img.titulo
        p ⭐ #{img.valoracion_promedio} (#{img.total_valoraciones})

  h2 Otras imágenes
  .galeria
    each img in otras
      .card
        a(href=`/publicacion/${img.publicacion_id}`)
          img(src=img.ruta_archivo alt=img.titulo)
        p= img.titulo